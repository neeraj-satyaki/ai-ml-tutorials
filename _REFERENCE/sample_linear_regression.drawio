  <diagram id="linreg" name="Linear Regression Flow">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="start" value="Start: init w,b (zeros)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="340" y="40" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="forward" value="Forward: y_hat = X·w + b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="340" y="130" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="error" value="error = y_hat − y" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="340" y="220" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="grad" value="grad_w = Xᵀ·error / n&#10;grad_b = mean(error)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="340" y="310" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="update" value="w ← w − lr·grad_w&#10;b ← b − lr·grad_b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="340" y="410" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="check" value="Converged?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="350" y="510" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="done" value="Return w, b" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="340" y="630" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="start" target="forward"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="forward" target="error"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="error" target="grad"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="grad" target="update"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="update" target="check"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="yes" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="check" target="done"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="no" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=1;entryY=0.5" edge="1" parent="1" source="check" target="forward">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="650" y="550" /><mxPoint x="650" y="155" /></Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
