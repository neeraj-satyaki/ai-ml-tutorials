        <mxCell id="ealBand" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b0b0b0;dashed=1" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="1080" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ealLabel" value="EAL + Poll Mode Drivers (PMDs)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none" vertex="1" parent="1">
          <mxGeometry x="50" y="325" width="300" height="20" as="geometry" />
        </mxCell>

        <mxCell id="eal" value="EAL - Environment Abstraction Layer&#10;(hugepage init, per-core pinning,&#10;PCI scan, memory allocator, launch remote lcores)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="340" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pmdNet" value="NIC PMDs&#10;mlx5 / ice / i40e / ixgbe /&#10;virtio-net / vmxnet3 / ena" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="420" y="350" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pmdVirt" value="Virt PMDs&#10;vhost-user / virtio-user /&#10;AF_XDP / TAP / ring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="660" y="350" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pmdCrypto" value="Crypto / DMA PMDs&#10;QAT, mlx5_crypto,&#10;ioat_dma, idxd" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="880" y="350" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- ======= LAYER 3: KERNEL BIND ======= -->
        <mxCell id="kBand" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#a8a8a8;dashed=1" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="1080" height="80" as="geometry" />
        </mxCell>
        <mxCell id="kLabel" value="Linux Kernel - NIC Binding Layer (kernel bypassed for data path)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none" vertex="1" parent="1">
          <mxGeometry x="50" y="465" width="600" height="20" as="geometry" />
        </mxCell>

        <mxCell id="vfio" value="vfio-pci&#10;(IOMMU-enforced, production default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="uio" value="uio / igb_uio&#10;(legacy, no IOMMU)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="360" y="490" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="mlxDirect" value="Mellanox (mlx5) direct verbs&#10;(no bind needed; uses rdma-core)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="620" y="490" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="hugetlb" value="hugetlbfs / hugepages&#10;(2 MB or 1 GB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="920" y="490" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- ======= LAYER 2: PCIE / DMA ======= -->
        <mxCell id="pcie" value="PCIe bus + DMA engines (MMIO registers, IOMMU translations, MSI-X interrupts disabled for data path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="1080" height="50" as="geometry" />
        </mxCell>

        <!-- ======= LAYER 1: HARDWARE ======= -->
        <mxCell id="hwBand" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b0b0b0;dashed=1" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="1080" height="140" as="geometry" />
        </mxCell>
        <mxCell id="hwLabel" value="Hardware" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none" vertex="1" parent="1">
          <mxGeometry x="50" y="635" width="140" height="20" as="geometry" />
        </mxCell>

        <mxCell id="hwNic" value="NIC&#10;ConnectX-6/7/8, Intel E810,&#10;Broadcom Thor,&#10;SmartNIC / BlueField DPU&#10;RX/TX descriptor rings&#10;RSS + hw offloads" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5e1a5;strokeColor=#558b2f" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hwCpu" value="CPU Cores&#10;isolated via isolcpus / cpuset&#10;pinned lcores&#10;AVX-512 / ARM NEON&#10;busy-poll, no preemption" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5e1a5;strokeColor=#558b2f" vertex="1" parent="1">
          <mxGeometry x="340" y="660" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hwMem" value="Memory&#10;NUMA-local&#10;Hugepages backing mbuf pools&#10;Rings in same socket as NIC&#10;Cacheline-aligned structs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5e1a5;strokeColor=#558b2f" vertex="1" parent="1">
          <mxGeometry x="600" y="660" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hwAcc" value="Accelerators&#10;QAT crypto, IDXD DMA,&#10;FPGA SmartNICs,&#10;DPU ARM cores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c5e1a5;strokeColor=#558b2f" vertex="1" parent="1">
          <mxGeometry x="860" y="660" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- ======= SIDE NOTE: polling vs interrupt ======= -->
        <mxCell id="note" value="Key: Data plane bypasses kernel.&#10;Cores spin in tight poll loops on&#10;NIC descriptor rings + rte_ring.&#10;No syscalls, no context switches,&#10;no interrupts in steady state." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#ffffcc;strokeColor=#a6a600;align=left" vertex="1" parent="1">
          <mxGeometry x="740" y="20" width="250" height="90" as="geometry" />
        </mxCell>

        <!-- ======= ARROWS up the stack ======= -->
        <!-- Hardware to kernel bind via PCIe -->
        <mxCell id="a1" style="endArrow=classic;html=1;startArrow=classic;startFill=1;endFill=1;strokeColor=#555" edge="1" parent="1" source="hwNic" target="pcie">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" style="endArrow=classic;html=1;startArrow=classic;startFill=1;endFill=1;strokeColor=#555" edge="1" parent="1" source="pcie" target="vfio">
