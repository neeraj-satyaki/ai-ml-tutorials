        </mxCell>
        <mxCell id="a3" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="hugetlb" target="eal">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Kernel bind to PMD / EAL -->
        <mxCell id="a4" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="vfio" target="pmdNet">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a5" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="mlxDirect" target="pmdNet">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- EAL/PMD to libs -->
        <mxCell id="a6" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="eal" target="libMempool">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a7" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="pmdNet" target="libEther">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a8" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="pmdCrypto" target="libCrypto">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- libs to app -->
        <mxCell id="a9" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="libMbuf" target="appPipeline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a10" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="libHash" target="appFlow">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a11" style="endArrow=classic;html=1;strokeColor=#555" edge="1" parent="1" source="libEther" target="appDataplanes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Slow-path back to kernel -->
        <mxCell id="a12" value="exception pkts" style="endArrow=classic;html=1;strokeColor=#b85450;dashed=1" edge="1" parent="1" source="appCtrl" target="vfio">
